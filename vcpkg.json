{
    "name": "libdigidocpp",
    "dependencies": [
      {
        "name": "libxml2",
        "default-features": false
      },
      "xmlsec",
      "zlib"
    ],
    "features": {
      "tests": { "description": "Build tests", "dependencies": ["boost-test"] }
    },
    "builtin-baseline": "4008642a50a01a7115c2406b04d5273898e7fe1c",
    "vcpkg-configuration": {
        "overlay-triplets": ["./vcpkg-triplets"],
        "overlay-ports": [
          "vcpkg-ports/openssl",
          "vcpkg-ports/xmlsec"
        ]
    }
}
